@page "/kaamelott"
@inject HttpClient Http
@inject FavorisService FavorisService
<h1>Kaamelott</h1>

<div>
    <legend>Filtrer les citations</legend>
    <label>Filtrer par personnage :</label>
    <input @bind="filtrePersonnage" @bind:event="oninput" placeholder="ex: Gauvain" />
    <label>Filtrer par saison :</label>
    <input @bind="filtreSaison" @bind:event="oninput" placeholder="ex: Livre 1" />
    <button @onclick="AppliquerFiltres">Appliquer les filtres</button>
</div>

@if (citations == null)
{
    <p><em>Loading...</em></p>
}
else
{
    var affichees = citationsAffichees ?? citations;
    var paginees = affichees.Skip((pageCourante - 1) * taillePage).Take(taillePage).ToList();
    int totalPages = (int)Math.Ceiling((double)affichees.Count / taillePage);

    @if (!affichees.Any())
    {
        <p><em>Aucune citation trouvée.</em></p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Personnage</th>
                    <th>Saison</th>
                    <th>Episode</th>
                    <th>Citation</th>
                    <th>Bouton Magique</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var quote in paginees)
                {
                    <tr>
                        <td>@quote.Infos.Personnage</td>
                        <td>@quote.Infos.Saison</td>
                        <td>@quote.Infos.Episode</td>
                        <td class="row-quote">@quote.Citation</td>
                        <td><button @onclick="() => AjouterFavori(quote)" disabled="@FavorisService.EstEnFavoris(quote)">Ajouter Favori</button></td> <!-- Désactive le bouton si la citation est déjà dans les favoris -->
                    </tr>
                }
            </tbody>
        </table>

        <div>
            <button @onclick="PagePrecedente" disabled="@(pageCourante <= 1)">Précédent</button>
            <span>Page @pageCourante / @totalPages</span>
            <button @onclick="PageSuivante" disabled="@(pageCourante >= totalPages)">Suivant</button>
        </div>
    }
}
@code{
    private KaamelottResponse? response;
    private List<KaamelottCitation>? citations;
    private string filtrePersonnage = "";
    private string filtreSaison = "";
    private List<KaamelottCitation>? citationsAffichees;
    private int pageCourante = 1;
    private int taillePage = 15;

    protected override async Task OnInitializedAsync()
    {
        await FavorisService.InitialiserAsync();
        response = await Http.GetFromJsonAsync<KaamelottResponse>("http://localhost:5138/api/kaamelott");
        citations = response?.Citation;
    }
    private void PagePrecedente() { if (pageCourante > 1) pageCourante--; }
    private void PageSuivante() { pageCourante++; }

    private void AppliquerFiltres()
    {
        filtrePersonnage = filtrePersonnage.Trim();
        filtreSaison = filtreSaison.Trim();

        citationsAffichees = (string.IsNullOrWhiteSpace(filtrePersonnage) && string.IsNullOrWhiteSpace(filtreSaison))
            ? citations
            : citations?.Where(c =>
                (string.IsNullOrWhiteSpace(filtrePersonnage) || c.Infos.Personnage.Contains(filtrePersonnage, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrWhiteSpace(filtreSaison) || c.Infos.Saison.Contains(filtreSaison, StringComparison.OrdinalIgnoreCase))
              ).ToList();
        pageCourante = 1;
    }

    private async Task AjouterFavori(KaamelottCitation citation)
    {
        await FavorisService.AjouterAsync(citation);
    }
}
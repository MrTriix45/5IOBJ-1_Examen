@inject NavigationManager NavigationManager
@inject MyAppBlazorThomas.Services.CompteService CompteService
@page "/"
@page "/login"
<EditForm Model="loginModel" OnValidSubmit="HandleLogin">
    <InputText @bind-Value="loginModel.Login" placeholder="Login" />
    <InputText @bind-Value="loginModel.Password" type="password" placeholder="Mot de passe" />

    <button type="submit">Login</button>
</EditForm>

@code {
    private LoginModel loginModel = new();

    protected override async Task OnInitializedAsync()
    {
        await CompteService.InitialiserAsync();
        if (CompteService.EstConnecte)
        {
            NavigationManager.NavigateTo("/kaamelott");
        }
    }

    private async Task HandleLogin()
    {
        if (!string.IsNullOrWhiteSpace(loginModel.Login) && loginModel.Password == "1234")
        {
            await CompteService.ConnexionAsync(loginModel.Login);
            NavigationManager.NavigateTo("/kaamelott");
        }
        else
        {
            NavigationManager.NavigateTo("/not-found");
        }
    }

    public class LoginModel
    {
        public string Login { get; set; }
        public string Password { get; set; }
    }
}